#!/bin/bash
set -e

function ok {
  printf "\r\e[032m[ OK ]\e[0m\n"
}

function stage {
  printf "[    ] $1..."
}

branch=$(git branch | grep "*" | cut -f2 -d' ')
if [[ "$branch" = "master" ]]
then
  echo -e "\e[31mCurrently on branch master so aborting\e[0m"
  exit 1
fi

echo -e "\e[32mMerging branch $branch onto master\e[0m"

stage "Fetching latest"
git fetch > /dev/null
ok
stage "Rebase on top of origin/master"
git rebase origin/master > /dev/null
ok
stage "Reset local master to origin/master"
git checkout master -q
git reset origin/master --hard > /dev/null
ok
stage "Merge $branch onto local master"
git merge $branch > /dev/null
ok

read -r -p "Want me to git push for you? [y/N] " response
response=${response,,}
if [[ $response =~ ^(yes|y)$ ]]
then
  git push
fi

echo -e "\e[32mDone\e[0m"
exit 0
