#!/bin/bash
# Usage: update_projects.sh [gem_name]
#   It goes on each subfolder and upgrade the specified [gem_name]
#   If [gem_name] is left empty will look for any project depending on 
#   api_client/restful_resource
#   and update those two gems

updated_gems=${1:-'api_client\|restful_resource'}

update_projects() {
  updated_gems=$1
  gemfiles=$(find . -maxdepth 2 -mindepth 2 -iname Gemfile -exec grep -l "$updated_gems" {} \;)

  for file in $gemfiles
  do
    folder=$(dirname $file)
    update_gems $folder $updated_gems 
  done
}

update_gems() {
  project_name=$(basename $1)
  updated_gems=$2

  gems=$(grep $updated_gems $1/Gemfile |\
    grep -v "#" |\
    sed -r "s/gem '([a-z\_0-9\-]+)'.*/\1/")

  pushd $project_name > /dev/null
  bundle update $gems &> /dev/null
  if [[ $? == 0 ]]
  then
    if ! git_has_local_changes
    then
      if commit_changes $updated_gems
      then
        success $project_name
      else
        failed $project_name 'commit changes failed'
      fi
    else
      no_update $project_name
    fi
  else
    failed $project_name 'bundle update failed'
  fi
  popd > /dev/null
}

git_has_local_changes() {
  git diff-index --quiet HEAD --
}

commit_changes() {
  updated_gems=$1
  gems=$(echo "$updated_gems" | sed "s/[\|]/ /g")

  git add Gemfile.lock
  git commit -m "Updated $gems" > /dev/null
  return $?
}

red() { printf "\e[031m$1\e[0m"; }
green() { printf "\e[032m$1\e[0m"; }
blue() { printf "\e[034m$1\e[0m"; }
purple() { printf "\e[035m$1\e[0m"; }

no_update() {
  purple "\rokay     "
  blue "$1\n"
}

success() {
  green "\rupdated  "
  blue "$1\n"
}

failed() {
  red "\rfailed   "
  blue "$1 $2\n"
}

update_projects $updated_gems
