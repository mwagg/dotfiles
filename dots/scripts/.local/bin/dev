#!/usr/bin/env bash

action=${1:-up}

case $action in
  up)
    sudo systemctl start docker.service
    if [[ -d $HOME/dev/carwow/dev-environment ]]; then
      $HOME/dev/carwow/dev-environment/bin/carwow start core
    fi
    ;;

  down)
    if [[ -d $HOME/dev/carwow/dev-environment ]]; then
      $HOME/dev/carwow/dev-environment/bin/carwow stop all
    fi
    sudo systemctl stop docker.service
    ;;
esac
