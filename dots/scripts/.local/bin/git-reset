#!/bin/bash

set -euo pipefail
IFS=$'\n\t'

update_all() {
  dirs=$(find . -maxdepth 2 -name '.git')

  for dir in $dirs
  do
    project_dir=$(dirname $dir)
    project=$(basename $project_dir)

    echo "$project"

    pushd $project_dir > /dev/null

    if [[ -d ".git" ]]
    then
      git checkout master --quiet
      git fetch --quiet
      git reset origin/master --hard --quiet
    fi

    popd > /dev/null
  done
}

update_all
