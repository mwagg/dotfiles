[
  {
    "name": "Change wallpaper",
    "command": "$HOME/.local/bin/randomise-wallpaper"
  },
  {
    "name": "Connect to VPN",
    "command": "/usr/bin/nmcli connection up id VyprVPN"
  },
  {
    "name": "Disconnect from VPN",
    "command": "/usr/bin/nmcli connection down id VyprVPN"
  },
  {
    "name": "Change VPN location",
    "command": "$HOME/.local/bin/change-vpn-location"
  },
  {
    "name": "Power off",
    "confirm": true,
    "command": "systemctl poweroff"
  },
  {
    "name": "Reboot",
    "confirm": true,
    "command": "systemctl reboot"
  },
  {
    "name": "Suspend",
    "confirm": true,
    "command": "systemctl suspend"
  },
  {
    "name": "Lock",
    "command": "/usr/bin/i3lock -c 000000 -i /home/mike/.config/i3lock/lock.png"
  }
]
